rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Deny read/write by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // --- LEVELED COLLECTIONS ---

    // 1. Producao Weekly Record
    match /producao/{semanaId} {
      allow read, write: if isSignedIn();
    }

    // 2. Custos Weekly Record
    match /custos/{custosId} {
      allow read, write: if isSignedIn();
    }

    // 3. Qualidade Weekly Record
    match /qualidade/{qualidadeId} {
      allow read, write: if isSignedIn();
    }

    // 4. Metas (Goals configurations)
    match /metas/{indicadorId} {
      allow read, write: if isSignedIn();
    }

    // 5. Usuarios Directory
    match /usuarios/{userId} {
      allow read, write: if isSignedIn();
    }
  }
}
